  "variables": [
    {
      "id": "GAD2FeelNervScale",
      "name": "Generalized Anxiety Disorder feeling nervous scale",
      "description": "Scale describing how often participant/subject has been bothered by feeling nervous, anxious or on edge, as a part of Generalized Anxiety Disorder (GAD-2), (GAD-7) and Patient Health Questionnaire 4 (PHQ-4)",
      "action": "",
      "element_type": "variable",
      "metadata": {
        "short_description": "Scale describing how often participant/subject has been bothered by feeling nervous, anxious or on edge, as a part of Generalized Anxiety Disorder (GAD-2), (GAD-7) and Patient Health Questionnaire 4 (PHQ-4)",
        "crf_name": "Generalized Anxiety Disorder-2 (GAD-2) ",
        "question_text": "Over the last 2 weeks how often have you been bothered by the following problems: feeling nervous, anxious, or on edge",
        "references": "Kroenke K, Spitzer RL, Williams JB, Monahan PO, Löwe B. Anxiety disorders in primary care: Prevalence, impairment, comorbidity, and detection. Ann Intern Med. 2007;146:317-25.",
        "enum": [
          "0",
          "1",
          "2",
          "3"
        ],
        "permissible_values": {
          "0": "Not at all",
          "1": "Several days",
          "2": "More than half the days",
          "3": "Nearly every day"
        },
        "instructions": "Choose one.",
        "study_variable_mappings": {
          "HDP00253": [
            "c_gad_1",
